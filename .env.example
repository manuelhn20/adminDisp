# ═══════════════════════════════════════════════════════════════════════════
# Admin Disp - Environment Configuration Template
# Copy this file to .env and fill in your actual values (don't commit .env)
# ═══════════════════════════════════════════════════════════════════════════

# ─── Base de datos principal (admin_disp) ───────────────────────────────────
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=SSPROIMA100
DB_DATABASE=admin_disp
DB_USER=sa
DB_PASSWORD=
DB_TRUSTED=false

# ─── Base de datos empleados ───────────────────────────────────────────────
EMP_DRIVER=ODBC Driver 18 for SQL Server
EMP_SERVER=SSPROIMA100
EMP_DATABASE=empleados
EMP_USER=sa
EMP_PASSWORD=proima
EMP_TRUSTED=false

# ─── Configuración SMTP para envío de emails ────────────────────────────────
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true

# ─── Microsoft 365 / Graph API / SharePoint ────────────────────────────────
# Comunes para múltiples integraciones (Kardex, Empleados, etc.)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ─── SharePoint (General) ───────────────────────────────────────────────────
SP_SITE_HOSTNAME=proimamericanos.sharepoint.com
SP_SITE_PATH=/sites/ERPNext-Reportes
SP_DRIVE_NAME=Reportes Power Bi
SP_FILENAME=RPT---AT---Empleados.xlsx
SP_FOLDER_PATH=

# ─── Graph API / OneDrive (Opcional) ────────────────────────────────────────
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
MS_GRAPH_SITE_ID=
MS_GRAPH_DRIVE_PATH_ROOT=

# ─── SharePoint CxC (Cobranzas) ─────────────────────────────────────────────
# Usa las mismas credenciales de MS_* si es la misma aplicación Azure
CXC_SP_TENANT_ID=
CXC_SP_CLIENT_ID=
CXC_SP_CLIENT_SECRET=
CXC_SP_SITE_HOSTNAME=proimamericanos.sharepoint.com
CXC_SP_SITE_PATH=/sites/PROIMADEV
CXC_SP_LIST_NAME=PR6_CxC_Seguimiento
CXC_SP_BASIC_USER=
CXC_SP_BASIC_PASSWORD=

# ─── Configuración de la aplicación ────────────────────────────────────────
SECRET_KEY=dev-secret-change-in-production
